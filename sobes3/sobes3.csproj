<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<EnableDefaultCompileItems>false</EnableDefaultCompileItems>
	</PropertyGroup>

	<PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
		<DefineConstants>WINDOWS</DefineConstants>
	</PropertyGroup>
	<PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
		<DefineConstants>LINUX</DefineConstants>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="MetricCollector.cs" />
		<Compile Include="NetworkCollector.cs" />
		<Compile Include="Configuration.cs" />
		<Compile Include="Program.cs" />
		<Compile Include="CpuCollector.cs" />
		<Compile Include="MemoryCollector.cs" />
	</ItemGroup>

	<ItemGroup Condition="'$(OS)' == 'Windows_NT'">
		<Compile Include="CpuCollector.Windows.cs" />
		<Compile Include="MemoryCollector.Windows.cs" />
		<PackageReference Include="System.Diagnostics.PerformanceCounter" Version="8.0.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(OS)' != 'Windows_NT'">
		<Compile Include="CpuCollector.Linux.cs" />
		<Compile Include="MemoryCollector.Linux.cs" />
	</ItemGroup>
</Project>